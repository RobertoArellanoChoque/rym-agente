# Variables de entorno requeridas por my-app. Copiar a .env.local y completar.
# NUNCA commitear .env.local con valores reales.

# --- Base de datos (Postgres/Seenode) ---
# Session pooler recomendado. Ver lib/db/index.ts.
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Clerk (autenticación) ---
# Producción: usar las keys pk_live_ / sk_live_ de la instancia de producción.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Proveedores de IA ---
ANTHROPIC_API_KEY=sk-ant-xxx      # chat / agente
MISTRAL_API_KEY=xxx               # OCR de PDFs + extracción
OPENAI_API_KEY=sk-xxx             # matching de conciliación

# --- Opcional ---
# Directorio de archivos OCR temporales (default: ~/.rym-agente/sessions)
# SESSION_BASE=/ruta/a/sessions
